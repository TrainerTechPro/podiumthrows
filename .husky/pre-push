# Pre-push verification.
#
# Gates: typecheck → lint. Keeps obviously-broken code out of feat/* branches
# so CI doesn't burn a run on a typo. Vitest + e2e are CI's responsibility
# now that we use feat/* + auto-merge — see memory/project_setup_auto_merge_workflow.md.
#
# Escape hatch: SKIP_VERIFY=1 git push

set -e

if [ "$SKIP_VERIFY" = "1" ]; then
  echo "⚠️  SKIP_VERIFY=1 — skipping pre-push verification"
  exit 0
fi

echo "▸ typecheck"
npm run typecheck

echo "▸ lint"
npm run lint

echo "✓ pre-push checks passed"
