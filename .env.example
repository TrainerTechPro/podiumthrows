# =============================================================================
# Podium Throws — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Lines starting with # are comments; commented-out vars are optional.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Vercel Postgres)
# -----------------------------------------------------------------------------
# Pooled connection string (used by Prisma at runtime via PgBouncer)
POSTGRES_PRISMA_URL=postgresql://user:pass@host:5432/db?pgbouncer=true
# Direct connection string (used by Prisma for migrations / db push)
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host:5432/db

# -----------------------------------------------------------------------------
# Auth (Custom JWT — HttpOnly cookies, 7-day expiry, bcrypt)
# -----------------------------------------------------------------------------
JWT_SECRET=generate-a-strong-random-string-here

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# NOTE: Named NEXT_PUBLIC_ but only used server-side (Stripe redirects, emails,
# sitemap, metadata). Kept for backward compatibility with existing deploys.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe (Free / Pro / Elite tiers)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...    # TODO: create annual prices
# STRIPE_PRICE_ELITE_ANNUAL=price_...  # TODO: create annual prices

# -----------------------------------------------------------------------------
# Email — Resend (used for lead capture / welcome emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM=Podium Throws <noreply@podiumthrows.com>

# -----------------------------------------------------------------------------
# Email — SMTP (used for password reset / transactional emails)
# -----------------------------------------------------------------------------
# Falls back to Ethereal (test inbox) if not set
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Podium Throws <noreply@podiumthrows.com>

# -----------------------------------------------------------------------------
# Cloudflare R2 (Video Storage)
# -----------------------------------------------------------------------------
# All five must be set for R2 uploads to be enabled; otherwise stubbed out
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=podium-throws-videos
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Cron Jobs (Vercel Cron)
# -----------------------------------------------------------------------------
CRON_SECRET=generate-a-strong-random-string-here

# -----------------------------------------------------------------------------
# Rate Limiting — Upstash Redis (optional)
# -----------------------------------------------------------------------------
# Falls back to in-memory store if not set (sufficient for local dev).
# Required for production to persist rate limits across serverless cold starts.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# -----------------------------------------------------------------------------
# AI / ThrowFlow (optional — powers AI session analysis)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# THROWFLOW_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# External APIs (optional)
# -----------------------------------------------------------------------------
# RAPIDAPI_KEY=...          # Muscle visualizer API

# -----------------------------------------------------------------------------
# Error Monitoring (optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://...
