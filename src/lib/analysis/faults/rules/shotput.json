{
  "version": "shotput-rules-1.0.0",
  "event": "SHOT_PUT",
  "rules": [
    {
      "ruleId": "early_shoulder_opening",
      "faultName": "Early shoulder opening",
      "metricKey": "hip_shoulder_separation_at_power_position",
      "comparator": "below",
      "targetRange": [35, 45],
      "unit": "deg",
      "severityBands": [
        { "deviationGte": 0, "severity": "LOW" },
        { "deviationGte": 8, "severity": "MEDIUM" },
        { "deviationGte": 15, "severity": "HIGH" }
      ],
      "minConfidence": 0.5,
      "drillTags": ["separation"],
      "coachTunable": true
    },
    {
      "ruleId": "low_release_angle",
      "faultName": "Release angle too low",
      "metricKey": "release_angle",
      "comparator": "below",
      "targetRange": [32, 40],
      "unit": "deg",
      "severityBands": [
        { "deviationGte": 0, "severity": "LOW" },
        { "deviationGte": 5, "severity": "MEDIUM" },
        { "deviationGte": 10, "severity": "HIGH" }
      ],
      "minConfidence": 0.5,
      "drillTags": ["release_mechanics"],
      "coachTunable": true
    },
    {
      "ruleId": "high_release_angle",
      "faultName": "Release angle too high",
      "metricKey": "release_angle",
      "comparator": "above",
      "targetRange": [32, 40],
      "unit": "deg",
      "severityBands": [
        { "deviationGte": 0, "severity": "LOW" },
        { "deviationGte": 5, "severity": "MEDIUM" },
        { "deviationGte": 10, "severity": "HIGH" }
      ],
      "minConfidence": 0.5,
      "drillTags": ["release_mechanics"],
      "coachTunable": true
    },
    {
      "ruleId": "soft_block_knee",
      "faultName": "Soft block leg at release",
      "metricKey": "block_knee_angle_at_release",
      "comparator": "below",
      "targetRange": [160, 180],
      "unit": "deg",
      "severityBands": [
        { "deviationGte": 0, "severity": "LOW" },
        { "deviationGte": 10, "severity": "MEDIUM" },
        { "deviationGte": 25, "severity": "HIGH" }
      ],
      "minConfidence": 0.5,
      "drillTags": ["block"],
